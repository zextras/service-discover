pkgname="service-discover-daemon"
pkgver="0.2.2"
pkgrel="1"
pkgdesc="Service discover daemon"
maintainer="Zextras <packages@zextras.com>"
copyright=('2022, Zextras <https://www.zextras.com>')
arch=('x86_64')
license=("AGPL-3.0-only")
section="admin"
priority="optional"
url="https://github.com/zextras"
conflicts=("consul")
depends=(
  "carbonio-core"
  "service-discover-base"
)
source=(
  "service-discoverd-docker"
  "systemd-tmpfile.conf"
)
sha256sums=(
  'SKIP'
  'e2f6bdb437c040a32046999a7a4b14b10698765a03d59b92a61f9267a97a87a0'
)

build() {
  cd "$(dirname "$(find / -name "yap.json" -print -quit)")/.."
  CGO_ENABLED=0 go build \
    -o "${srcdir}/service-discoverd" \
    cmd/service-discoverd/service-discoverd.go
}

package() {
  cd "${srcdir}"
  install -Dm 755 service-discoverd \
    "${pkgdir}/usr/bin/service-discoverd"
  install -Dm 755 service-discoverd-docker \
    "${pkgdir}/usr/bin/service-discoverd-docker"

  # systemd tmpfiles.d
  install -Dm644 systemd-tmpfile.conf \
    "${pkgdir}/usr/lib/tmpfiles.d/${pkgname}.conf"
}

postinst() {
  systemd-tmpfiles --create /usr/lib/tmpfiles.d/service-discover-daemon.conf >/dev/null 2>&1 || :
}

postrm__apt() {
  if [ "$1" = "purge" ]; then
    echo 'Data have been left in the file system. In order to perform a final purge'
    echo 'please check documentation on'
    echo 'https://docs.zextras.com/carbonio-ce/html/uninstall.html'
  fi
}

postrm__yum() {
  if [ $1 -eq 0 ]; then
    echo 'Data have been left in the file system. In order to perform a final purge'
    echo 'please check documentation on'
    echo 'https://docs.zextras.com/carbonio-ce/html/uninstall.html'
  fi
}

pkgname="service-discover-agent"
pkgver="0.3.0"
pkgrel="1"
pkgdesc="Service discover agent cli"
maintainer="Zextras <packages@zextras.com>"
copyright=('2022, Zextras <https://www.zextras.com>')
arch=('x86_64')
license=("AGPL-3.0-only")
section="admin"
priority="optional"
url="https://github.com/zextras"
provides=(
  "service-discover"
)
depends=(
  "envoyproxy"
  "service-discover-base"
  "service-discover-daemon"
  "service-discover-template"
)
conflicts=(
  "service-discover-server"
)
source=(
  "service-discover.service"
  "service-discover-legacy.service"
)
sha256sums=(
  '24d801a607705c6134d0ed4efd08f3badab46d15c669d6238f5dc046b0be374b'
  'e0e17bae0bfb978dd52718a03079eaf30c2bf5dba080ca98c2964eb42e02bf14'
)

_package_legacy() {
  cd "${srcdir}"
  install -Dm755 agent \
    "${pkgdir}/usr/bin/service-discover"
  install -Dm644 service-discover-legacy.service \
    "${pkgdir}/lib/systemd/system/service-discover.service"
}

_package_systemd() {
  cd "${srcdir}"
  install -Dm755 agent \
    "${pkgdir}/usr/bin/service-discover"
  install -Dm644 service-discover.service \
    "${pkgdir}/lib/systemd/system/service-discover.service"
}

build() {
  cd "$(dirname "$(find / -name "yap.json" -print -quit)")/.."
  CGO_ENABLED=0 go build \
    -o "${srcdir}/agent" \
    cmd/agent/agent.go
}

package() {
  _package_systemd
}

package__rocky_8() {
  _package_legacy
}

package__rocky_9() {
  _package_systemd
}

package__ubuntu_jammy() {
  _package_legacy
}

package__ubuntu_noble() {
  _package_systemd
}

postinst__apt() {
  if [ -d /run/systemd/system ]; then
    systemctl daemon-reload &>/dev/null || :
    if [ "$1" = "configure" ] && [ -z "$2" ]; then
      systemctl enable service-discover.service &>/dev/null || :
    fi
  fi

  echo "Installed, run service-discover setup-wizard on first installation."
}

postinst__yum() {
  if [ -d /run/systemd/system ]; then
    systemctl daemon-reload &>/dev/null || :
    if [ $1 -eq 1 ]; then
      systemctl enable service-discover.service &>/dev/null || :
    fi
  fi

  echo "Installed, run service-discover setup-wizard on first installation."
}

postrm() {
  if [ -d /run/systemd/system ]; then
    systemctl daemon-reload >/dev/null 2>&1 || :
  fi
}

prerm__apt() {
  if [ -d /run/systemd/system ]; then
    case "$1" in
      remove)
        systemctl --no-reload disable --now service-discover.service &>/dev/null || :
        ;;
      upgrade)
        systemctl --no-reload stop service-discover.service &>/dev/null || :
        ;;
    esac
  fi
}

prerm__yum() {
  if [ -d /run/systemd/system ]; then
    if [ $1 -eq 0 ]; then
      systemctl --no-reload disable --now service-discover.service &>/dev/null || :
    else
      systemctl --no-reload stop service-discover.service &>/dev/null || :
    fi
  fi
}

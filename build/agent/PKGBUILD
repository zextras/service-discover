pkgname="service-discover-agent"
pkgver="0.2.0"
pkgrel="1"
pkgdesc="Service discover agent cli"
maintainer="Zextras <packages@zextras.com>"
copyright=('2022, Zextras <https://www.zextras.com>')
arch=('x86_64')
license=("AGPL-3.0-only")
section="admin"
priority="optional"
url="https://github.com/zextras"
provides=(
  "service-discover"
)
depends=(
  "envoyproxy"
  "service-discover-base"
  "service-discover-daemon"
  "service-discover-template"
)
conflicts=(
  "service-discover-server"
)
source=("service-discover.service")
sha256sums=('SKIP')

build() {
  cd "/tmp/service-discover"
  CGO_ENABLED=0 go build \
    -o "${srcdir}/agent" \
    cmd/agent/agent.go
}

package() {
  cd "${srcdir}"
  install -Dm 755 agent \
    "${pkgdir}/usr/bin/service-discover"
  install -Dm 644 service-discover.service \
    "${pkgdir}/lib/systemd/system/service-discover.service"
}

postinst__apt() {
  # Automatically added by dh_systemd_enable/11.1.6ubuntu2
  if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ]; then
    # This will only remove masks created by d-s-h on package removal.
    deb-systemd-helper unmask 'service-discover.service' >/dev/null || true

    # was-enabled defaults to true, so new installations run enable.
    if deb-systemd-helper --quiet was-enabled 'service-discover.service'; then
      # Enables the unit on first installation, creates new
      # symlinks on upgrades if the unit file has changed.
      deb-systemd-helper enable 'service-discover.service' >/dev/null || true
    else
      # Update the statefile to add new symlinks (if any), which need to be
      # cleaned up on purge. Also remove old symlinks.
      deb-systemd-helper update-state 'service-discover.service' >/dev/null || true
    fi
  fi
  # End automatically added section
  echo "Installed, run service-discover setup-wizard on first installation."
}

postinst__yum() {
  if [ -d /run/systemd/system ]; then
    systemctl daemon-reload >/dev/null 2>&1 || :
  fi
  echo "Installed, run service-discover setup-wizard on first installation."
}

prerm__apt() {
  if [ -d /run/systemd/system ]; then
    deb-systemd-invoke stop 'service-discover.service' >/dev/null || true
  fi
}

prerm__yum() {
  if [ $1 -eq 0 ]; then
    # Package removal, not upgrade
    if [ -d /run/systemd/system ]; then
      systemctl --no-reload disable videoserver.service >/dev/null 2>&1 || :
      systemctl stop videoserver.service >/dev/null 2>&1 || :
    fi
  fi
}

postrm__apt() {
  if [ -d /run/systemd/system ]; then
    systemctl --system daemon-reload >/dev/null || true
  fi
  # Automatically added by dh_systemd_enable/11.1.6ubuntu2
  if [ "$1" = "remove" ]; then
    if [ -x "/usr/bin/deb-systemd-helper" ]; then
      deb-systemd-helper mask 'service-discover.service' >/dev/null || true
    fi
  fi

  if [ "$1" = "purge" ]; then
    if [ -x "/usr/bin/deb-systemd-helper" ]; then
      deb-systemd-helper purge 'service-discover.service' >/dev/null || true
      deb-systemd-helper unmask 'service-discover.service' >/dev/null || true
    fi
  fi
  # End automatically added section
  # Automatically added by dh_installdebconf/11.1.6ubuntu2
  if [ "$1" = purge ] && [ -e /usr/share/debconf/confmodule ]; then
    . /usr/share/debconf/confmodule
    db_purge
  fi
}

postrm__yum() {
  if [ -d /run/systemd/system ]; then
    systemctl daemon-reload >/dev/null 2>&1 || :
  fi
}

pkgname="service-discover-server"
pkgver="0.7.1"
pkgrel="1"
pkgdesc="Service discover server cli"
maintainer="Zextras <packages@zextras.com>"
copyright=('2022, Zextras <https://www.zextras.com>')
arch=('aarch64' 'x86_64')
license=("AGPL-3.0-only")
section="admin"
priority="optional"
url="https://github.com/zextras"
provides=(
  "service-discover"
)
depends=(
  "carbonio-prometheus-consul-exporter"
  "envoyproxy"
  "service-discover-base"
  "service-discover-daemon"
  "service-discover-template"
)
conflicts=("service-discover-agent")
source=(
  "service-discover.service"
  "service-discover-legacy.service"
)
sha256sums=(
  '60e9d0caed05c4f654257df8ee27925d67e18c10ed848120f425495f59d852b9'
  '5780163ac614276da1c812580686eb8adfdbfe9eebe62397d6a354ca461db1a9'
)

_package_legacy() {
  cd "${srcdir}"
  install -Dm755 server \
    "${pkgdir}/usr/bin/service-discover"
  install -Dm644 service-discover-legacy.service \
    "${pkgdir}/lib/systemd/system/service-discover.service"
}

_package_systemd() {
  cd "${srcdir}"
  install -Dm755 server \
    "${pkgdir}/usr/bin/service-discover"
  install -Dm644 service-discover.service \
    "${pkgdir}/lib/systemd/system/service-discover.service"
}

build() {
  cd "${repodir}"
  CGO_ENABLED=0 go build \
    -o "${srcdir}/server" \
    cmd/server/server.go
}

package() {
  _package_systemd
}

package__rocky_8() {
  _package_legacy
}

package__rocky_9() {
  _package_systemd
}

package__ubuntu_jammy() {
  _package_legacy
}

package__ubuntu_noble() {
  _package_systemd
}

postinst__apt() {
  if [ -d /run/systemd/system ]; then
    systemctl daemon-reload &>/dev/null || :
    # Enable on both fresh install and upgrade so the [Install] WantedBy=
    # symlink is always reconciled against the current unit (self-healing).
    if [ "$1" = "configure" ]; then
      systemctl enable service-discover.service &>/dev/null || :
    fi
  fi

  echo "Installed, run service-discover setup-wizard on first installation."
}

postinst__yum() {
  if [ -d /run/systemd/system ]; then
    systemctl daemon-reload &>/dev/null || :
    # Enable on both fresh install ($1 -eq 1) and upgrade ($1 -eq 2) so the
    # [Install] WantedBy= symlink is always reconciled (self-healing).
    if [ $1 -ge 1 ]; then
      systemctl enable service-discover.service &>/dev/null || :
    fi
  fi

  echo "Installed, run service-discover setup-wizard on first installation."
}

postrm() {
  if [ -d /run/systemd/system ]; then
    systemctl daemon-reload >/dev/null 2>&1 || :
  fi
}

prerm__apt() {
  if [ -d /run/systemd/system ]; then
    case "$1" in
      remove)
        systemctl --no-reload disable --now service-discover.service &>/dev/null || :
        ;;
      upgrade)
        systemctl --no-reload stop service-discover.service &>/dev/null || :
        ;;
    esac
  fi
}

prerm__yum() {
  if [ -d /run/systemd/system ]; then
    if [ $1 -eq 0 ]; then
      systemctl --no-reload disable --now service-discover.service &>/dev/null || :
    else
      systemctl --no-reload stop service-discover.service &>/dev/null || :
    fi
  fi
}

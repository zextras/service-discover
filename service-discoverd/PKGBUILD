targets=(
  "centos"
  "ubuntu"
)
pkgname="service-discover-daemon"
pkgver="0.1.0"
pkgrel="1"
pkgdesc="Service discover daemon"
pkgdesclong=(
  "Service discover binary daemon"
)
maintainer="Zextras srl <packages@zextras.com>"
arch="amd64"
license=("PROPRIETARY")
section="admin"
priority="optional"
url="https://www.zextras.com/"
conflicts=("consul")
depends=(
  "service-discover-base"
)
sources=(
  "/repo/"
)
hashsums=(
  "SKIP"
)

postinst:ubuntu() {
    adduser --system --group --home '/var/lib/service-discover/' 'service-discover'
    mkdir -p '/etc/zextras/service-discover/'
    mkdir -p '/var/lib/service-discover/'
    chown 'service-discover:service-discover' '/var/lib/service-discover/'
}

postinst:centos() {
    getent group 'service-discover' >/dev/null || \
        groupadd -r 'service-discover'
    getent passwd 'service-discover' >/dev/null || \
        useradd -r -g 'service-discover' -d '/var/lib/service-discover/' -s /sbin/nologin 'service-discover'

    mkdir -p '/etc/zextras/service-discover/'
    mkdir -p '/var/lib/service-discover/'
    chown 'service-discover:service-discover' '/var/lib/service-discover/'
}

build() {
  cd "service-discoverd/"
  go build .
}

package() {
  install -Dm 755 service-discoverd/service-discoverd "${pkgdir}/usr/bin/service-discoverd"
}

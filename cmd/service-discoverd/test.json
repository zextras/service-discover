{
  "acl": {
    "default_policy": "deny",
    "down_policy": "extend-cache",
    "enable_token_persistence": true,
    "enabled": true
  },
  "auto_encrypt": {
    "allow_tls": true
  },
  "connect": {
    "ca_provider": "",
    "enabled": true
  },
  "data_dir": "/var/lib/service-discover/data",
  "enable_local_script_checks": true,
  "encrypt": "ELImtwre/oob36+WAqcYM1fvBwBnWe7NqqHosziDwFA=",
  "log_level": "INFO",
  "node_name": "server-mail-carbonio-test",
  "ports": {
    "grpc": 8502,
    "grpc_tls": 8503
  },
  "server": true,
  "ui_config": {
    "enabled": true
  },
  "tls": {
    "defaults": {
      "ca_file": "/var/lib/service-discover/consul-agent-ca.pem",
      "cert_file": "/var/lib/service-discover/dc1-server-consul-0.pem",
      "key_file": "/var/lib/service-discover/dc1-server-consul-0-key.pem",
      "verify_incoming": true,
      "verify_outgoing": true
    },
    "internal_rpc": {
      "verify_server_hostname": true
    }
  }
}
